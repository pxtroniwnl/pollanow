# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# football-data.org (https://www.football-data.org/client/register) -> tier gratis
FOOTBALL_DATA_API_KEY=your-football-data-token

# Secreto para proteger el endpoint /api/cron/sync (cabecera Authorization: Bearer ...)
CRON_SECRET=genera-un-string-aleatorio-largo

# Iteraciones de la simulacion Monte Carlo (opcional, default 20000)
MONTECARLO_ITERATIONS=20000
